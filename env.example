# Copia este archivo como .env y ajusta los valores para tu entorno
# NO subas el .env real al repositorio

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/viva-eventos

# ── Base de datos (en Docker usa el nombre del contenedor) ────────────────────
DB_URL=jdbc:postgresql://localhost:5432/ticketdb
DB_DRIVER=org.postgresql.Driver
DB_USER=ticket_user
DB_PASSWORD=ticket_pass

# ── URL del event-service ─────────────────────────────────────────────────────
# En Docker: http://event-service:8081
# En local:  http://localhost:8081
EVENT_SERVICE_URL=http://localhost:8081
